        self.label.setStyleSheet("background-color: rgba(0, 0, 0, 180); color: white; padding: 5px; border-radius: 5px;")
        self.label.setWordWrap(True)
        self.label.setGeometry(0, 0, width, height)

    def set_translated_text(self, text):
        self.label.setText(text)
        # 根据文本内容和原始区域大小，可能需要动态调整 label 或窗口大小
        self.show()

